# ─────────────────────────────────────────────────────────────────────────────
# KROENG USK – Docker Environment Template
# Salin file ini: cp .env.docker.example .env.docker
# Lalu isi semua nilai di bawah sebelum menjalankan docker compose
# ─────────────────────────────────────────────────────────────────────────────

# ─── 1. Generate JWT_SECRET ───────────────────────────────────────────────────
# Jalankan: openssl rand -base64 32
JWT_SECRET=GANTI_INI_jwt_secret_minimal_32_karakter_acak

# ─── 2. Generate ANON_KEY dan SERVICE_ROLE_KEY ───────────────────────────────
# Gunakan: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Atau pakai jwt.io dengan payload berikut (ganti JWT_SECRET di atas):
#
# ANON_KEY payload:
#   { "role": "anon", "iss": "supabase", "iat": <unix_now>, "exp": <unix_now + 315360000> }
#
# SERVICE_ROLE_KEY payload:
#   { "role": "service_role", "iss": "supabase", "iat": <unix_now>, "exp": <unix_now + 315360000> }
#
ANON_KEY=GANTI_INI_anon_jwt_token
SERVICE_ROLE_KEY=GANTI_INI_service_role_jwt_token

# ─── 3. Database ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=GANTI_INI_password_postgres_yang_kuat

# ─── 4. Supabase Studio ───────────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=GANTI_INI_password_studio

# ─── 5. URL Eksternal ─────────────────────────────────────────────────────────
# Ganti dengan IP address Raspberry Pi di jaringan lokal.
# Ini adalah URL yang BROWSER gunakan untuk menjangkau Supabase API (port 8000)
# dan aplikasi Next.js (port 3000).
#
# Contoh jika IP Pi = 192.168.1.50:
#   API_EXTERNAL_URL=http://192.168.1.50:8000
#   NEXT_PUBLIC_SUPABASE_URL=http://192.168.1.50:8000
#   NEXT_PUBLIC_SITE_URL=http://192.168.1.50:3000
#
API_EXTERNAL_URL=http://192.168.1.XXX:8000
NEXT_PUBLIC_SUPABASE_URL=http://192.168.1.XXX:8000
NEXT_PUBLIC_SITE_URL=http://192.168.1.XXX:3000

# ─── 6. SMTP (opsional — untuk email verifikasi) ─────────────────────────────
# Tanpa ini, user tidak bisa verifikasi email. Bisa pakai Gmail App Password.
# Aktifkan di Gmail: myaccount.google.com/apppasswords
SMTP_ADMIN_EMAIL=noreply@kroengusk.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=emailkamu@gmail.com
SMTP_PASS=gmail_app_password_16_karakter

# ─── 7. Webhook (opsional) ────────────────────────────────────────────────────
# Jalankan: openssl rand -hex 32
WEBHOOK_SECRET=GANTI_INI_webhook_secret
